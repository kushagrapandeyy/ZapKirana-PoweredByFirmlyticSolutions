enum ScannerWorkflow {
  GOODS_RECEIVING
  STOCK_AUDIT
  PRODUCT_INTAKE
  LOOSE_ITEM_PACKING
  ORDER_PICKING
  SHELF_REFILL
  DAMAGED_EXPIRED
  LABEL_REPRINT
  POS_BILLING
}

enum ScanResolutionStatus {
  FOUND
  UNKNOWN_BARCODE
  INTERNAL_BARCODE
  OPERATIONAL_BARCODE
  ERROR
}

model ScannerEvent {
  id               String               @id @default(cuid())
  storeId          String
  store            Store                @relation(fields: [storeId], references: [id])
  deviceId         String?
  device           ScannerDevice?       @relation(fields: [deviceId], references: [id])
  scannedById      String?
  scannedBy        User?                @relation("ScannedByUser", fields: [scannedById], references: [id])
  workflow         ScannerWorkflow
  rawValue         String
  symbology        String?
  parsedJson       Json?
  resolutionStatus ScanResolutionStatus @default(FOUND)
  idempotencyKey   String               @unique
  quantity         Decimal?             @db.Decimal(12, 3)
  metadata         Json?
  createdAt        DateTime             @default(now())

  @@index([storeId, workflow, createdAt])
  @@index([storeId, createdAt])
}

model ScannerSession {
  id              String        @id @default(cuid())
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id])
  deviceId        String
  device          ScannerDevice @relation(fields: [deviceId], references: [id])
  staffId         String
  staff           User          @relation(fields: [staffId], references: [id])
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  durationSeconds Int?

  @@index([storeId, startedAt])
  @@index([staffId])
}

// =====================================================
// BARCODE REGISTRY & LABELS
// =====================================================

enum BarcodeScope {
  GS1_EXTERNAL_PRODUCT
  INTERNAL_FIXED_PACK
  INTERNAL_VARIABLE_WEIGHT
  INTERNAL_OPERATIONAL
  UNKNOWN
}

model BarcodeRegistry {
  id             String        @id @default(cuid())
  storeId        String?
  store          Store?        @relation(fields: [storeId], references: [id])
  storeProductId String?
  storeProduct   StoreProduct? @relation(fields: [storeProductId], references: [id])
  barcodeValue   String
  symbology      String        @default("EAN_13")
  barcodeScope   BarcodeScope  @default(GS1_EXTERNAL_PRODUCT)
  isInternal     Boolean       @default(false)
  isPrimary      Boolean       @default(true)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())

  @@unique([barcodeValue, storeId])
  @@index([barcodeValue])
  @@index([storeId, barcodeScope])
}

enum PrintJobStatus {
  PENDING
  READY
  PRINTED
  FAILED
}

model PrintJob {
  id            String         @id @default(cuid())
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id])
  requestedById String?
  requestedBy   User?          @relation("PrintJobs", fields: [requestedById], references: [id])
  templateType  String
  labelDataJson Json
  status        PrintJobStatus @default(PENDING)
  r2PdfPath     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([storeId, status])
}

// =====================================================
// PENDING PRODUCT (UNKNOWN BARCODE INTAKE)
// =====================================================

enum PendingProductStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model PendingProduct {
  id                String               @id @default(cuid())
  storeId           String
  store             Store                @relation(fields: [storeId], references: [id])
  productId         String?
  product           Product?             @relation(fields: [productId], references: [id])
  barcode           String?
  suggestedName     String?
  suggestedBrand    String?
  suggestedCategory String?
  mrp               Decimal?             @db.Decimal(12, 2)
  sellingPrice      Decimal?             @db.Decimal(12, 2)
  purchasePrice     Decimal?             @db.Decimal(12, 4)
  gstRate           Decimal              @default(0) @db.Decimal(5, 2)
  hsnSac            String?
  baseUnit          String?
  purchaseUnit      String?
  conversionToBase  Decimal?             @db.Decimal(12, 3)
  supplierId        String?
  imageUrl          String?
  status            PendingProductStatus @default(PENDING_REVIEW)
  createdById       String?
  createdBy         User?                @relation("CreatedPendingProducts", fields: [createdById], references: [id])
  approvedProductId String?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([storeId, status])
}

// =====================================================
// CONSUMER CARTS
// =====================================================

model Cart {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, storeId])
}

model CartItem {
  id             String       @id @default(cuid())
  cartId         String
  cart           Cart         @relation(fields: [cartId], references: [id])
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])
  quantity       Decimal      @db.Decimal(12, 3)

  @@unique([cartId, storeProductId])
}

// =====================================================
// USER PREFERENCES & ANALYTICS
// =====================================================

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  dietaryTags       String[]
  favoriteBrands    String[]
  pricePreference   String?
  preferredStoreId  String?
  language          String   @default("en")
  notificationPrefs Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ProductView {
  id             String       @id @default(cuid())
  userId         String?
  sessionId      String?
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])
  storeId        String
  duration       Int?
  createdAt      DateTime     @default(now())

  @@index([userId, storeProductId])
  @@index([storeId, createdAt])
}

model ProductClick {
  id             String       @id @default(cuid())
  userId         String?
  sessionId      String?
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])
  storeId        String
  source         String?
  createdAt      DateTime     @default(now())

  @@index([userId, storeProductId])
  @@index([storeId, createdAt])
}

model RecommendationEvent {
  id               String   @id @default(cuid())
  userId           String?
  sessionId        String?
  algorithm        String
  recommendedItems String[]
  clickedItemId    String?
  createdAt        DateTime @default(now())
}

model CartEvent {
  id             String       @id @default(cuid())
  userId         String?
  sessionId      String?
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])
  storeId        String
  action         String
  quantity       Decimal      @db.Decimal(12, 3)
  createdAt      DateTime     @default(now())

  @@index([userId, storeProductId])
  @@index([storeId, createdAt])
}

// =====================================================
// CAMPAIGNS
// =====================================================

model StoreCampaign {
  id                 String    @id @default(cuid())
  storeId            String
  store              Store     @relation(fields: [storeId], references: [id])
  title              String
  description        String?
  type               String    @default("OFFER")
  imageUrl           String?
  displayOrder       Int       @default(0)
  discountPercentage Decimal   @db.Decimal(5, 2)
  animationType      String    @default("DEFAULT")
  isActive           Boolean   @default(true)
  startsAt           DateTime  @default(now())
  endsAt             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  products StoreProduct[] @relation("CampaignProducts")

  @@index([storeId, isActive])
}

// =====================================================
// SUPPORT TICKETS
// =====================================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id           String          @id @default(cuid())
  storeId      String?
  store        Store?          @relation(fields: [storeId], references: [id])
  customerId   String?
  customer     User?           @relation("CustomerTickets", fields: [customerId], references: [id])
  orderId      String?
  order        Order?          @relation(fields: [orderId], references: [id])
  assignedToId String?
  assignedTo   User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  title        String
  description  String
  status       TicketStatus    @default(OPEN)
  priority     TicketPriority  @default(MEDIUM)
  messages     TicketMessage[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([storeId, status])
  @@index([customerId, status])
  @@index([assignedToId, status])
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id])
  senderId   String
  sender     User          @relation("SentTicketMessages", fields: [senderId], references: [id])
  text       String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([ticketId, createdAt])
}

// =====================================================
// ZAP CREDIT (UDHAR / CREDIT LEDGER)
// =====================================================

model ZapCreditLedger {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  customerId   String
  customer     User     @relation(fields: [customerId], references: [id])
  staffId      String?
  amount       Decimal  @db.Decimal(12, 2)
  balanceAfter Decimal  @db.Decimal(14, 2)
  note         String?
  posBillId    String?
  createdAt    DateTime @default(now())

  @@index([customerId])
  @@index([storeId, createdAt])
}

// =====================================================
// SCANNER AI EXTRACTION
// =====================================================

model ScannerExtraction {
  id              String                   @id @default(cuid())
  storeId         String
  type            String
  status          String
  rawText         String?
  imageUrl        String?
  confidenceScore Float?
  fields          ScannerExtractionField[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model ScannerExtractionField {
  id             String            @id @default(cuid())
  extractionId   String
  extraction     ScannerExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)
  fieldKey       String
  extractedValue String?
  confidence     Float?
  isEdited       Boolean           @default(false)
  finalValue     String?
}

// =====================================================
// OFFLINE SYNC & CONFLICT RESOLUTION
// =====================================================

enum SyncEventStatus {
  PENDING
  PROCESSED
  CONFLICT
  FAILED
}

model OfflineSyncEvent {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  deviceId       String
  localEventId   String
  idempotencyKey String          @unique
  operationType  String
  payload        Json
  baseVersion    Int?
  status         SyncEventStatus @default(PENDING)
  conflictReason String?

  createdAtDevice  DateTime
  receivedAtServer DateTime  @default(now())
  processedAt      DateTime?

  @@unique([storeId, localEventId, deviceId])
}

// =====================================================
// ADMIN GOVERNANCE & AUDIT
// =====================================================

model AdminInterventionLog {
  id                        String   @id @default(cuid())
  adminUserId               String
  adminUser                 User     @relation("AdminInterventions", fields: [adminUserId], references: [id])
  targetType                String
  targetId                  String
  storeId                   String?
  store                     Store?   @relation(fields: [storeId], references: [id])
  action                    String
  reason                    String
  beforeSnapshot            Json?
  afterSnapshot             Json?
  ipAddress                 String?
  deviceInfo                String?
  requiresStoreNotification Boolean  @default(false)
  createdAt                 DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  user       User?    @relation("UserAudits", fields: [userId], references: [id])
  details    String?
  createdAt  DateTime @default(now())
}

// =====================================================
// MESSAGES
// =====================================================

model OrderMessage {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())
}
