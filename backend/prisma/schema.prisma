generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      Role     @default(CUSTOMER)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  movements      StockMovement[]
  posBills       PosBill[]
  customerOrders Order[] @relation("CustomerOrders")
  staffOrders    Order[] @relation("StaffOrders")
}

enum Role {
  OWNER
  PARTNER
  MANAGER
  STAFF
  DELIVERY
  CUSTOMER
}

model Store {
  id          String   @id @default(uuid())
  name        String
  location    String?
  gstin       String?
  isActive    Boolean  @default(true)
  users       User[]
  products    Product[]
  inventory   Inventory[]
  movements   StockMovement[]
  posBills    PosBill[]
  orders      Order[]
  supplierConnections StoreSupplierConnection[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  barcode        String?
  internalSku    String   @unique
  name           String
  description    String?
  category       String?
  mrp            Float
  sellingPrice   Float
  purchaseCost   Float?
  gstRate        Float    @default(0)
  imageUrl       String?
  isActive       Boolean  @default(true)
  inventory      Inventory[]
  movements      StockMovement[]
  posBillItems   PosBillItem[]
  orderItems     OrderItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([storeId])
}

model Inventory {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  batchNo        String?
  expiryDate     DateTime?
  onHandQty      Int      @default(0)
  reservedQty    Int      @default(0)
  blockedQty     Int      @default(0)
  movements      StockMovement[]
  
  // Available Qty = onHandQty - reservedQty - blockedQty
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, productId, batchNo])
}

model StockMovement {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  inventoryId    String
  inventory      Inventory @relation(fields: [inventoryId], references: [id])
  type           MovementType
  quantityChange Int
  sourceType     String?  // e.g., "ONLINE_ORDER", "POS_SALE", "SUPPLIER_DELIVERY"
  sourceId       String?
  reason         String?
  staffId        String?
  staff          User?    @relation(fields: [staffId], references: [id])
  createdAt      DateTime @default(now())
}

enum MovementType {
  STOCK_RECEIVED
  POS_SALE
  ONLINE_ORDER_RESERVED
  ONLINE_ORDER_PICKED
  ORDER_CANCELLED
  RETURN_ACCEPTED
  DAMAGED
  EXPIRED
  MANUAL_ADJUSTMENT
  STOCK_COUNT_CORRECTION
}

enum BillStatus {
  DRAFT
  PAYMENT_PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

model PosBill {
  id        String        @id @default(uuid())
  storeId   String
  store     Store         @relation(fields: [storeId], references: [id])
  staffId   String?
  staff     User?         @relation(fields: [staffId], references: [id])
  status    BillStatus    @default(DRAFT)
  subtotal  Float         @default(0)
  gst       Float         @default(0)
  total     Float         @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  items     PosBillItem[]
  payments  PosPayment[]
}

model PosBillItem {
  id          String   @id @default(uuid())
  billId      String
  bill        PosBill  @relation(fields: [billId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  priceAtSale Float
  gstAtSale   Float    @default(0)
  createdAt   DateTime @default(now())
}

model PosPayment {
  id            String        @id @default(uuid())
  billId        String
  bill          PosBill       @relation(fields: [billId], references: [id])
  amount        Float
  method        PaymentMethod
  referenceId   String?
  createdAt     DateTime      @default(now())
}

// -----------------------------------------------------
// Sprint 3: Consumer Orders & Supplier Network
// -----------------------------------------------------

enum OrderStatus {
  PAYMENT_PENDING
  PAID
  PICKING
  READY_FOR_PICKUP
  DELIVERED
  CANCELLED
}

model Order {
  id          String        @id @default(uuid())
  storeId     String
  store       Store         @relation(fields: [storeId], references: [id])
  customerId  String
  customer    User          @relation("CustomerOrders", fields: [customerId], references: [id])
  staffId     String?       // Picker
  staff       User?         @relation("StaffOrders", fields: [staffId], references: [id])
  status      OrderStatus   @default(PAYMENT_PENDING)
  totalAmount Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items       OrderItem[]
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  priceAtOrder Float
}

model Supplier {
  id           String   @id @default(uuid())
  name         String
  contactEmail String?
  contactPhone String?
  categories   String?  // comma separated or JSON
  rating       Float    @default(5.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storeConnections StoreSupplierConnection[]
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  REJECTED
}

model StoreSupplierConnection {
  id         String           @id @default(uuid())
  storeId    String
  store      Store            @relation(fields: [storeId], references: [id])
  supplierId String
  supplier   Supplier         @relation(fields: [supplierId], references: [id])
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([storeId, supplierId])
}
