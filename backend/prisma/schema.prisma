model SupplierImportBatch {
  id         String  @id @default(cuid())
  storeId    String
  fileName   String?
  uploadedBy String?
  status     String  @default("PENDING_REVIEW")

  totalRows     Int @default(0)
  validRows     Int @default(0)
  invalidRows   Int @default(0)
  duplicateRows Int @default(0)

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  rows      SupplierImportRow[]
  suppliers Supplier[]
}

model SupplierImportRow {
  id      String              @id @default(cuid())
  batchId String
  batch   SupplierImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  storeId String

  rowNumber         Int?
  rawData           Json?
  parsedData        Json?
  validationStatus  String  @default("PENDING")
  validationErrors  Json?
  matchedSupplierId String?

  createdAt DateTime @default(now())
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  REJECTED
}

model StoreSupplierConnection {
  id         String           @id @default(cuid())
  storeId    String
  store      Store            @relation(fields: [storeId], references: [id])
