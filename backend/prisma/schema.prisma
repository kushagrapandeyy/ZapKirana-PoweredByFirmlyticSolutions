generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  phone     String?  @unique
  role      Role     @default(CUSTOMER)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  avatarUrl String?
  isVerified Boolean @default(false)
  pushToken  String?  // Expo push notification token
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  movements      StockMovement[]
  posBills       PosBill[]
  customerOrders Order[] @relation("CustomerOrders")
  staffOrders    Order[] @relation("StaffOrders")
  sentMessages   OrderMessage[] @relation("SentMessages")
  audits         AuditLog[] @relation("UserAudits")
  savedAddresses SavedAddress[]
  subscriptions  Subscription[]
  otpCodes       OtpCode[]
}

enum Role {
  OWNER
  PARTNER
  MANAGER
  STAFF
  DELIVERY
  CUSTOMER
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  phone     String?
  email     String?
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([email])
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  label     String   // e.g. "Home", "Office"
  address   String
  latitude  Float
  longitude Float
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Store {
  id          String   @id @default(uuid())
  name        String
  location    String?
  latitude    Float?
  longitude   Float?
  operatingRadiusKm Float @default(3.0)
  gstin       String?
  isActive    Boolean  @default(true)
  imageUrl    String?
  operatingHours String? // JSON: {"mon": {"open": "08:00", "close": "22:00"}, ...}
  rating      Float    @default(4.5)
  description String?
  users       User[]
  products    Product[]
  inventory   Inventory[]
  movements   StockMovement[]
  posBills    PosBill[]
  orders      Order[]
  supplierConnections StoreSupplierConnection[]
  subscriptions Subscription[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Onboarding & Payment Details
  bankAccountNumber String?
  bankRoutingNumber String?
  taxId             String?

  purchaseOrders    PurchaseOrder[]
}

// -----------------------------------------------------
// GST Classification System
// -----------------------------------------------------

enum GSTClass {
  EXEMPT     // 0% - Essential items: milk, fresh vegetables, fruits, eggs
  GST_5      // 5% - Packaged food, edible oil, sugar, spices, tea, coffee
  GST_12     // 12% - Processed food, butter, cheese, ghee, fruit juices, namkeen
  GST_18     // 18% - Biscuits, pasta, cornflakes, soups, ice cream, sauces
  GST_28     // 28% - Aerated beverages, chewing gum, pan masala
}

model Product {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  barcode        String?
  internalSku    String   @unique
  name           String
  description    String?
  category       String?
  mrp            Float
  sellingPrice   Float
  purchaseCost   Float?
  gstRate        Float    @default(0)
  gstClass       GSTClass @default(EXEMPT)
  imageUrl       String?
  isActive       Boolean  @default(true)
  inventory      Inventory[]
  movements      StockMovement[]
  posBillItems   PosBillItem[]
  orderItems     OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  supplierProducts SupplierProduct[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([storeId])
  @@index([category])
}

model Inventory {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  batchNo        String?
  expiryDate     DateTime?
  onHandQty      Int      @default(0)
  reservedQty    Int      @default(0)
  blockedQty     Int      @default(0)
  lowStockThreshold Int   @default(10)
  movements      StockMovement[]
  
  // Available Qty = onHandQty - reservedQty - blockedQty
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, productId, batchNo])
}

model StockMovement {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  inventoryId    String
  inventory      Inventory @relation(fields: [inventoryId], references: [id])
  type           MovementType
  quantityChange Int
  sourceType     String?  // e.g., "ONLINE_ORDER", "POS_SALE", "SUPPLIER_DELIVERY"
  sourceId       String?
  reason         String?
  staffId        String?
  staff          User?    @relation(fields: [staffId], references: [id])
  createdAt      DateTime @default(now())
}

enum MovementType {
  STOCK_RECEIVED
  POS_SALE
  ONLINE_ORDER_RESERVED
  ONLINE_ORDER_PICKED
  ORDER_CANCELLED
  RETURN_ACCEPTED
  DAMAGED
  EXPIRED
  MANUAL_ADJUSTMENT
  STOCK_COUNT_CORRECTION
}

enum BillStatus {
  DRAFT
  PAYMENT_PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

model PosBill {
  id        String        @id @default(uuid())
  storeId   String
  store     Store         @relation(fields: [storeId], references: [id])
  staffId   String?
  staff     User?         @relation(fields: [staffId], references: [id])
  status    BillStatus    @default(DRAFT)
  subtotal  Float         @default(0)
  gst       Float         @default(0)
  total     Float         @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  items     PosBillItem[]
  payments  PosPayment[]
}

model PosBillItem {
  id          String   @id @default(uuid())
  billId      String
  bill        PosBill  @relation(fields: [billId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  priceAtSale Float
  gstAtSale   Float    @default(0)
  createdAt   DateTime @default(now())
}

model PosPayment {
  id            String        @id @default(uuid())
  billId        String
  bill          PosBill       @relation(fields: [billId], references: [id])
  amount        Float
  method        PaymentMethod
  referenceId   String?
  createdAt     DateTime      @default(now())
}

// -----------------------------------------------------
// Consumer Orders & Delivery
// -----------------------------------------------------

enum OrderStatus {
  PAYMENT_PENDING
  PAID
  PICKING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id          String        @id @default(uuid())
  storeId     String
  store       Store         @relation(fields: [storeId], references: [id])
  customerId  String
  customer    User          @relation("CustomerOrders", fields: [customerId], references: [id])
  staffId     String?       // Picker
  staff       User?         @relation("StaffOrders", fields: [staffId], references: [id])
  status      OrderStatus   @default(PAYMENT_PENDING)
  totalAmount Float         @default(0)
  deliveryFee Float         @default(0)
  gstAmount   Float         @default(0)
  tipAmount   Float         @default(0)
  deliveryAddress String?
  deliveryLat Float?
  deliveryLng Float?
  deliverySlot String?      // e.g., "10:00-11:00"
  deliveryInstructions String?
  requireOtp  Boolean       @default(false)
  otp         String?       // Generated OTP code
  subscriptionId String?    // If order was created from a subscription
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items       OrderItem[]
  messages    OrderMessage[]
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  priceAtOrder Float
  gstAtOrder   Float    @default(0)
  gstClass     GSTClass @default(EXEMPT)
}

// -----------------------------------------------------
// Subscriptions (Recurring Orders)
// -----------------------------------------------------

enum SubscriptionFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id              String                @id @default(uuid())
  customerId      String
  customer        User                  @relation(fields: [customerId], references: [id])
  storeId         String
  store           Store                 @relation(fields: [storeId], references: [id])
  frequency       SubscriptionFrequency
  status          SubscriptionStatus    @default(ACTIVE)
  deliverySlot    String?               // e.g., "07:00-08:00"
  nextDeliveryDate DateTime?
  items           SubscriptionItem[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([customerId])
  @@index([storeId])
}

model SubscriptionItem {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  productId      String
  productName    String       // Denormalized for display
  quantity       Int
  createdAt      DateTime     @default(now())
}

// -----------------------------------------------------
// Supplier Network & Procurement
// -----------------------------------------------------

model Supplier {
  id           String   @id @default(uuid())
  name         String
  contactEmail String?
  contactPhone String?
  address      String?
  categories   String?  // comma separated or JSON
  rating       Float    @default(5.0)
  description  String?
  logoUrl      String?
  paymentTerms String?  // e.g., "Net 30", "COD"
  onTimeRate   Float    @default(100.0) // percentage
  fillRate     Float    @default(100.0) // percentage
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storeConnections StoreSupplierConnection[]
  purchaseOrders   PurchaseOrder[]
  supplierProducts SupplierProduct[]
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  REJECTED
}

model StoreSupplierConnection {
  id         String           @id @default(uuid())
  storeId    String
  store      Store            @relation(fields: [storeId], references: [id])
  supplierId String
  supplier   Supplier         @relation(fields: [supplierId], references: [id])
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([storeId, supplierId])
}

model OrderMessage {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  user       User?    @relation("UserAudits", fields: [userId], references: [id])
  details    String?
  createdAt  DateTime @default(now())
}

enum POStatus {
  CREATED
  SENT
  ACCEPTED
  PARTIALLY_ACCEPTED
  DELIVERED
  REJECTED
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  storeId              String
  store                Store               @relation(fields: [storeId], references: [id])
  supplierId           String
  supplier             Supplier            @relation(fields: [supplierId], references: [id])
  status               POStatus            @default(CREATED)
  expectedDeliveryDate DateTime?
  totalAmount          Float               @default(0)
  notes                String?
  shareToken           String?   @unique   // For shareable link access
  shareTokenExpiresAt  DateTime?           // Token expiry
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  
  items                PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  poId             String
  po               PurchaseOrder @relation(fields: [poId], references: [id])
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  quantity         Int
  acceptedQuantity Int           @default(0)
  receivedQuantity Int           @default(0)
  purchasePrice    Float
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model SupplierProduct {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([supplierId, productId])
}

// -----------------------------------------------------
// GST Category Auto-Classification Rules
// -----------------------------------------------------

model GSTCategoryRule {
  id        String   @id @default(uuid())
  category  String   @unique // Product category name
  gstClass  GSTClass
  gstRate   Float    // Numeric rate for calculation (0, 5, 12, 18, 28)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
