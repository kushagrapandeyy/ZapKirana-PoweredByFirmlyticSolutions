// =====================================================
// ERP IMPORT ENGINE
// =====================================================

enum LegacySystem {
  MARG_ERP
  BUSY
  TALLY
  VYAPAR
  EXCEL
  UNICOMMERCE
  CUSTOM
}

enum ImportEntityType {
  PRODUCT
  LEDGER
  SUPPLIER
  OPENING_STOCK
  OPENING_BALANCE
  PURCHASE_HISTORY
  SALES_HISTORY
  GST_MAPPING
}

enum ImportBatchStatus {
  UPLOADED
  DRY_RUN
  DRY_RUN_DONE
  CONFIRMED
  ROLLED_BACK
  FAILED
}

model ImportBatch {
  id           String            @id @default(cuid())
  storeId      String
  store        Store             @relation(fields: [storeId], references: [id])
  legacySystem LegacySystem
  entityType   ImportEntityType
  fileName     String?
  filePath     String?
  status       ImportBatchStatus @default(UPLOADED)

  totalRows     Int @default(0)
  validRows     Int @default(0)
  invalidRows   Int @default(0)
  duplicateRows Int @default(0)
  importedRows  Int @default(0)

  uploadedBy  String?
  confirmedBy String?
  confirmedAt DateTime?
  rollbackAt  DateTime?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rows           ImportRow[]
  columnMappings ImportColumnMapping[]
  legacyMappings LegacyEntityMapping[]
}

model ImportRow {
  id            String      @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  storeId       String

  rowNumber        Int?
  // Full original raw row from legacy ERP — never modified
  rawData          Json
  parsedData       Json?
  validationStatus String  @default("PENDING") // PENDING, VALID, INVALID, DUPLICATE, IMPORTED
  isDuplicate      Boolean @default(false)
  resolvedEntityId String? // ID of entity created after import

  createdAt DateTime @default(now())

  validationErrors ImportValidationError[]
}

model ImportColumnMapping {
  id            String      @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  legacyColumnName String // e.g., "CODE", "PRODUCT", "SGST %"
  targetColumnPath String // e.g., "storeProduct.legacyCode", "productTaxProfile.sgstRate"
  transformRule    String? // e.g., "parseDecimal", "toBoolean", "trimString"
  defaultValue     String?
  isRequired       Boolean @default(false)

  createdAt DateTime @default(now())
}

model ImportValidationError {
  id          String    @id @default(cuid())
  importRowId String
  importRow   ImportRow @relation(fields: [importRowId], references: [id], onDelete: Cascade)

  field        String
  legacyValue  String?
  errorCode    String
  errorMessage String
  severity     String  @default("ERROR") // ERROR, WARNING, INFO

  createdAt DateTime @default(now())

  @@index([importRowId])
}

// Master mapping of legacy IDs to ZapKirnana IDs — preserved forever
model LegacyEntityMapping {
  id            String       @id @default(cuid())
  storeId       String
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  legacySystem     LegacySystem
  legacyEntityType ImportEntityType
  // e.g. "001078", "AMAZON DISTRIBUTORS"
  legacyEntityId   String
  // Full original row from old ERP — never deleted
  rawLegacyPayload Json

  zapKirnanaEntityType String // Product, StoreProduct, PartyLedger, etc.
  zapKirnanaEntityId   String

  createdAt DateTime @default(now())

  @@unique([storeId, legacySystem, legacyEntityType, legacyEntityId])
  @@index([storeId, legacySystem])
}

