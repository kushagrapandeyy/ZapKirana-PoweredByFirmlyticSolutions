// =====================================================
// POS BILLING — WITH INVOICE SNAPSHOTTING
// =====================================================

enum BillStatus {
  DRAFT
  PAYMENT_PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  ZAPCREDIT
  CREDIT
}

model PosBill {
  id        String     @id @default(cuid())
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  staffId   String?
  staff     User?      @relation(fields: [staffId], references: [id])
  status    BillStatus @default(DRAFT)
  subtotal  Decimal    @default(0) @db.Decimal(12, 2)
  gst       Decimal    @default(0) @db.Decimal(12, 2)
  total     Decimal    @default(0) @db.Decimal(12, 2)
  discount  Decimal    @default(0) @db.Decimal(12, 2)
  roundOff  Decimal    @default(0) @db.Decimal(12, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items    PosBillItem[]
  payments PosPayment[]

  @@index([storeId, status])
  @@index([storeId, createdAt])
}

// Full invoice line snapshot — prices never recalculated from current product master
model PosBillItem {
  id             String       @id @default(cuid())
  billId         String
  bill           PosBill      @relation(fields: [billId], references: [id])
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  quantity Decimal @db.Decimal(12, 3)

  // Snapshot of product master at sale time
  productNameSnapshot String?
  barcodeSnapshot     String?
  hsnSacCodeSnapshot  String?
  unitSnapshot        String?
  batchSnapshot       String?
  expirySnapshot      DateTime?

  // Price snapshot
  mrpSnapshot            Decimal? @db.Decimal(12, 2)
  sellingPriceSnapshot   Decimal  @db.Decimal(12, 2)
  discountSnapshot       Decimal? @db.Decimal(5, 2)
  discountAmountSnapshot Decimal? @db.Decimal(12, 2)

  // Tax snapshot
  taxableValueSnapshot Decimal? @db.Decimal(12, 2)
  cgstRateSnapshot     Decimal? @db.Decimal(5, 2)
  cgstAmountSnapshot   Decimal? @db.Decimal(12, 2)
  sgstRateSnapshot     Decimal? @db.Decimal(5, 2)
  sgstAmountSnapshot   Decimal? @db.Decimal(12, 2)
  igstRateSnapshot     Decimal? @db.Decimal(5, 2)
  igstAmountSnapshot   Decimal? @db.Decimal(12, 2)
  cessRateSnapshot     Decimal? @db.Decimal(5, 2)
  cessAmountSnapshot   Decimal? @db.Decimal(12, 2)

  totalLineAmount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
}

model PosPayment {
  id          String        @id @default(cuid())
  billId      String
  bill        PosBill       @relation(fields: [billId], references: [id])
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  referenceId String?
  createdAt   DateTime      @default(now())
}

