generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// CORE ORGANIZATION & AUTH
// =====================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  legalName String?
  gstin     String?
  pan       String?
  plan      String   @default("FREE")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  stores         Store[]
  userStoreRoles UserStoreRole[]
}

model UserStoreRole {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  storeId         String
  store           Store        @relation(fields: [storeId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  role            Role
  permissionsJson Json?
  status          String       @default("ACTIVE")

  @@unique([storeId, userId])
}

enum Role {
  OWNER
  PARTNER
  MANAGER
  STAFF
  DELIVERY
  CUSTOMER
  SCANNER_STAFF
  POS_CASHIER
  ORG_ADMIN
  PLATFORM_ADMIN
}

model User {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  email          String        @unique
  password       String?
  pin            String?
  name           String?
  phone          String?       @unique
  role           Role          @default(CUSTOMER)
  storeId        String?
  store          Store?        @relation(fields: [storeId], references: [id])
  avatarUrl      String?
  isVerified     Boolean       @default(false)
  pushToken      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  storeRoles             UserStoreRole[]
  movements              StockMovement[]
  posBills               PosBill[]
  zapCreditBalance       Decimal           @default(0) @db.Decimal(14, 2)
  zapCreditLedger        ZapCreditLedger[]
  customerOrders         Order[]           @relation("CustomerOrders")
  staffOrders            Order[]           @relation("StaffOrders")
  sentMessages           OrderMessage[]    @relation("SentMessages")
  audits                 AuditLog[]        @relation("UserAudits")
  savedAddresses         SavedAddress[]
  subscriptions          Subscription[]
  otpCodes               OtpCode[]
  assignedDevices        ScannerDevice[]   @relation("AssignedDevices")
  scannerEvents          ScannerEvent[]    @relation("ScannedByUser")
  printJobs              PrintJob[]        @relation("PrintJobs")
  pendingProductsCreated PendingProduct[]  @relation("CreatedPendingProducts")
  ScannerSession         ScannerSession[]
  carts                  Cart[]
  preferences            UserPreferences?

  customerTickets    SupportTicket[]        @relation("CustomerTickets")
  assignedTickets    SupportTicket[]        @relation("AssignedTickets")
  sentTicketMessages TicketMessage[]        @relation("SentTicketMessages")
  adminInterventions AdminInterventionLog[] @relation("AdminInterventions")
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  phone     String?
  email     String?
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([email])
}

model SavedAddress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  label         String
  streetAddress String?
  landmark      String?
  city          String?
  state         String?
  pincode       String?
  address       String
  latitude      Float
  longitude     Float
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// =====================================================
// STORE
// =====================================================

model Store {
  id                String        @id @default(cuid())
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  name              String
  location          String?
  latitude          Float?
  longitude         Float?
  operatingRadiusKm Float         @default(3.0)
  gstin             String?
  pan               String?
  fssaiLicenseNo    String?
  isActive          Boolean       @default(true)
  imageUrl          String?
  logoUrl           String?
  bannerUrl         String?
  operatingHours    Json?
  rating            Float         @default(4.5)
  description       String?
  bankAccountNumber String?
  bankRoutingNumber String?
  taxId             String?
  stateCode         String?
  stateName         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  users                User[]
  userRoles            UserStoreRole[]
  storeProducts        StoreProduct[]
  inventory            Inventory[]
  movements            StockMovement[]
  posBills             PosBill[]
  orders               Order[]
  supplierConnections  StoreSupplierConnection[]
  suppliers            Supplier[]
  subscriptions        Subscription[]
  scannerDevices       ScannerDevice[]
  scannerEvents        ScannerEvent[]
  payments             Payment[]
  barcodeRegistry      BarcodeRegistry[]
  printJobs            PrintJob[]
  pendingProducts      PendingProduct[]
  purchaseOrders       PurchaseOrder[]
  ScannerSession       ScannerSession[]
  carts                Cart[]
  campaigns            StoreCampaign[]
  supportTickets       SupportTicket[]
  zapCreditLedgers     ZapCreditLedger[]
  tills                Till[]
  paymentLedgerEntries PaymentLedgerEntry[]
  offlineSyncEvents    OfflineSyncEvent[]
  adminInterventions   AdminInterventionLog[]
  stockBalances        StockBalance[]
  partyLedgers         PartyLedger[]
  productGroups        ProductGroup[]
  importBatches        ImportBatch[]
}

// =====================================================
// ERP PRODUCT MASTER — GLOBAL CATALOG
// =====================================================

model Brand {
  id             String   @id @default(cuid())
  name           String   @unique
  normalizedName String?
  country        String?
  logoUrl        String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products Product[]
}

model Manufacturer {
  id             String   @id @default(cuid())
  name           String   @unique
  normalizedName String?
  gstin          String?
  country        String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products Product[]
}

// Global product groups are org-level; store-level groups are ProductGroup
model GlobalCategory {
  id        String           @id @default(cuid())
  name      String           @unique
  parentId  String?
  parent    GlobalCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  GlobalCategory[] @relation("CategoryTree")
  iconUrl   String?
  sortOrder Int              @default(0)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  products Product[]
}

// Store-local product group (maps to MARG "GROUP")
model ProductGroup {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  createdAt DateTime @default(now())

  storeProducts StoreProduct[]

  @@unique([storeId, name])
}

// Global canonical product — identity only
model Product {
  id                   String          @id @default(cuid())
  name                 String
  normalizedName       String?
  baseUnit             String? // Pcs, Kg, Ltr, etc.
  brandId              String?
  brand                Brand?          @relation(fields: [brandId], references: [id])
  manufacturerId       String?
  manufacturer         Manufacturer?   @relation(fields: [manufacturerId], references: [id])
  categoryId           String?
  category             GlobalCategory? @relation(fields: [categoryId], references: [id])
  hsnSacCode           String? // Leading zeros preserved as string
  itemType             String? // NORMAL, SERVICE, etc.
  productType          String? // NORMAL, COMPOSITE, etc.
  packagingDescription String?
  allowDecimalQuantity Boolean         @default(false)
  imageUrl             String?
  metadata             Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  storeProducts   StoreProduct[]
  productBarcodes ProductBarcode[]
  pendingProducts PendingProduct[]
  productVersions ProductVersion[]
}

// =====================================================
// ERP PRODUCT MASTER — STORE-SPECIFIC LAYER
// =====================================================

model StoreProduct {
  id        String  @id @default(cuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // MARG: CODE (store-specific, TEXT not number)
  legacyCode      String?
  // MARG: PRODUCT display name override
  displayName     String?
  // MARG: STATUS
  status          String  @default("ACTIVE") // ACTIVE, INACTIVE, CONTINUE, DISCONTINUED
  // MARG: TYPE
  type            String? // NORMAL, SERVICE, etc.
  // MARG: ITEM TYPE
  itemType        String? // 1 NORMAL, 2 SERVICE, etc.
  // MARG: HIDE
  isHidden        Boolean @default(false)
  // MARG: DECIMAL
  allowDecimalQty Boolean @default(false)
  // MARG: PACKING
  packagingText   String?
  // MARG: COLOR TYPE
  colorType       String?

  // Classification
  groupId String?
  group   ProductGroup? @relation(fields: [groupId], references: [id])

  // MARG: MANUFACTURER F3
  manufacturerLegacyRef String?

  // Audit
  createdBy String?
  updatedBy String?
  source    String? @default("manual") // manual, scanner, erp_import
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inventory          Inventory[]
  movements          StockMovement[]
  posBillItems       PosBillItem[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  supplierProducts   SupplierProduct[]
  barcodeRegistry    BarcodeRegistry[]
  productBarcodes    StoreProductBarcode[]
  cartItems          CartItem[]
  productViews       ProductView[]
  productClicks      ProductClick[]
  cartEvents         CartEvent[]
  stockBalances      StockBalance[]
  campaigns          StoreCampaign[]       @relation("CampaignProducts")

  pricing         StoreProductPricing[]
  taxProfile      ProductTaxProfile[]
  inventoryPolicy ProductInventoryPolicy?
  discountPolicy  ProductDiscountPolicy?
  schemes         ProductScheme[]
  rackLocations   ProductRackLocation[]
  priceHistory    ProductPriceHistory[]
  costHistory     ProductCostHistory[]

  @@unique([storeId, legacyCode])
  @@index([storeId])
  @@index([storeId, isHidden])
  @@index([storeId, status])
}

// MARG: BARCODE (multiple per store-product)
model StoreProductBarcode {
  id             String       @id @default(cuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])
  barcode        String
  barcodeType    String? // EAN_13, EAN_8, QR, CODE_128, CUSTOM
  isPrimary      Boolean      @default(false)
  isActive       Boolean      @default(true)
  source         String? // manual, scanner, erp_import
  createdAt      DateTime     @default(now())

  @@unique([storeProductId, barcode])
  @@index([barcode])
}

// Global canonical barcode (for GS1 lookup)
model ProductBarcode {
  id          String   @id @default(cuid())
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  barcode     String
  barcodeType String?
  isPrimary   Boolean  @default(false)
  source      String?
  createdAt   DateTime @default(now())

  @@index([barcode])
}

// =====================================================
// PRICING — VERSIONED (ALL DECIMAL)
// =====================================================

// MARG: MRP, Rate-A, Rate-B, Rate-C, P.RATE, COST/PCS
model StoreProductPricing {
  id             String       @id @default(cuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  // MRP = printed maximum retail price
  mrp           Decimal? @db.Decimal(12, 2)
  // Default selling price
  sellingPrice  Decimal? @db.Decimal(12, 2)
  // MARG: Rate-A (wholesale tier)
  rateA         Decimal? @db.Decimal(12, 2)
  // MARG: Rate-B (distributor tier)
  rateB         Decimal? @db.Decimal(12, 2)
  // MARG: Rate-C (retail tier)
  rateC         Decimal? @db.Decimal(12, 2)
  // MARG: P.RATE (purchase rate from supplier)
  purchaseRate  Decimal? @db.Decimal(12, 4)
  // MARG: COST/PCS (landed cost per piece)
  costPerPiece  Decimal? @db.Decimal(12, 5)
  // Landing cost after freight/tax/discount
  landingCost   Decimal? @db.Decimal(12, 5)
  wholesaleRate Decimal? @db.Decimal(12, 2)
  retailRate    Decimal? @db.Decimal(12, 2)

  priceIncludesTax Boolean @default(true)
  currency         String  @default("INR")

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdBy     String?
  updatedBy     String?

  createdAt DateTime @default(now())

  @@index([storeProductId])
  @@index([storeProductId, effectiveFrom])
}

// Immutable price change history
model ProductPriceHistory {
  id             String       @id @default(cuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  changedField String // mrp, sellingPrice, rateA, etc.
  oldValue     Decimal? @db.Decimal(12, 5)
  newValue     Decimal? @db.Decimal(12, 5)
  reason       String?
  changedBy    String?
  approvedBy   String?

  createdAt DateTime @default(now())

  @@index([storeProductId])
}

// Cost history for purchase/GRN updates
model ProductCostHistory {
  id             String       @id @default(cuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  purchaseRate Decimal? @db.Decimal(12, 4)
  costPerPiece Decimal? @db.Decimal(12, 5)
  landingCost  Decimal? @db.Decimal(12, 5)
  sourceType   String? // GRN, MANUAL, IMPORT
  sourceId     String?
  changedBy    String?

  createdAt DateTime @default(now())

  @@index([storeProductId])
}

// =====================================================
// TAX PROFILE — VERSIONED GST
// =====================================================

// MARG: LOCAL TAX STATUS, CENTRAL TAX STATUS, SGST%, CGST%, IGST%, CESS%
model ProductTaxProfile {
  id             String       @id @default(cuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  hsnSacCode              String? // 04039090 — string to preserve leading zeros
  localTaxabilityStatus   String? // Taxable, Exempt, Nil
  centralTaxabilityStatus String? // Taxable, Exempt, Nil
  isTaxable               Boolean @default(true)

  // All GST rates as Decimal
  gstRate           Decimal? @db.Decimal(5, 2) // total = cgst+sgst
  cgstRate          Decimal? @db.Decimal(5, 2)
  sgstRate          Decimal? @db.Decimal(5, 2)
  igstRate          Decimal? @db.Decimal(5, 2)
  cessRate          Decimal? @db.Decimal(5, 2)
  cessAmountPerUnit Decimal? @db.Decimal(12, 2) // MARG: CESS fixed amount

  taxInclusive  Boolean   @default(true)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  source        String? // manual, erp_import, gstn_api
  createdBy     String?
  updatedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeProductId])
  @@index([hsnSacCode])
}

// =====================================================
// INVENTORY POLICY
// =====================================================

// MARG: CONV.BOX, MIN QTY, MAX QTY, DEFAULT SALE QTY, REORDER QTY, NEGATIVE, SHELFLIFE
model ProductInventoryPolicy {
  id             String       @id @default(cuid())
  storeProductId String       @unique
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  // MARG: NEGATIVE — default false
  allowNegativeStock Boolean  @default(false)
  // MARG: MINIMUM QTY
  minimumQty         Decimal? @db.Decimal(12, 3)
  // MARG: MAXIMUM QTY
  maximumQty         Decimal? @db.Decimal(12, 3)
  // MARG: REORDER QTY
  reorderQty         Decimal? @db.Decimal(12, 3)
  // MARG: DEFAULT SALE QTY
  defaultSaleQty     Decimal? @db.Decimal(12, 3)
  // MARG: CONV.BOX (box-to-piece conversion)
  boxConversionQty   Decimal? @db.Decimal(12, 3)

  // MARG: SHELFLIFE in days
  shelfLifeDays Int?
  trackBatch    Boolean @default(false)
  trackExpiry   Boolean @default(false)
  trackSerial   Boolean @default(false)

  // UOM separation
  stockUom    String?
  purchaseUom String?
  saleUom     String?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================================
// DISCOUNT & SCHEME POLICIES
// =====================================================

// MARG: DISCOUNT, V.DIS ON, ITEM DISC-1, DISC-2, SPECIAL DISC, MAX DISC%, 2nd DISC, ON QTY, PURC.DISC, DISC.LESS, F6/RATE±
model ProductDiscountPolicy {
  id             String       @id @default(cuid())
  storeProductId String       @unique
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  discountApplicable      Boolean  @default(false)
  // MARG: V.DIS ON
  visibleDiscountOn       Decimal? @db.Decimal(12, 2)
  // MARG: ITEM DISC-1
  itemDiscount1Percent    Decimal? @db.Decimal(5, 2)
  // MARG: DISC-2
  itemDiscount2Percent    Decimal? @db.Decimal(5, 2)
  // MARG: SPECIAL DISC
  specialDiscountPercent  Decimal? @db.Decimal(5, 2)
  // MARG: MAXIMUM DISCOUNT %
  maximumDiscountPercent  Decimal? @db.Decimal(5, 2)
  // MARG: SECOND DISCOUNT
  secondDiscountPercent   Decimal? @db.Decimal(5, 2)
  // MARG: DISC.LESS
  discountLessPercent     Decimal? @db.Decimal(5, 2)
  // MARG: PURC.Disc.
  purchaseDiscountPercent Decimal? @db.Decimal(5, 2)
  purchaseDiscountAmount  Decimal? @db.Decimal(12, 2)
  // MARG: ON QUANTITY
  appliesOnQuantity       Decimal? @db.Decimal(12, 3)
  // MARG: F6/RATE± — allow staff rate override
  rateOverrideAllowed     Boolean  @default(false)

  validFrom DateTime?
  validTo   DateTime?
  createdBy String?
  updatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// MARG: FREE SCHEME, VALID FROM
enum SchemeType {
  FREE_QTY
  FLAT_DISCOUNT
  PERCENT_DISCOUNT
  BUNDLE
  TIERED
}

model ProductScheme {
  id             String       @id @default(cuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  schemeType      SchemeType
  schemeName      String?
  // Buy X get Y free
  buyQty          Decimal?   @db.Decimal(12, 3)
  freeQty         Decimal?   @db.Decimal(12, 3)
  minimumQty      Decimal?   @db.Decimal(12, 3)
  maximumQty      Decimal?   @db.Decimal(12, 3)
  discountPercent Decimal?   @db.Decimal(5, 2)
  discountAmount  Decimal?   @db.Decimal(12, 2)

  appliesToSale     Boolean @default(true)
  appliesToPurchase Boolean @default(false)
  isActive          Boolean @default(true)

  validFrom DateTime?
  validTo   DateTime?
  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeProductId, isActive])
}

// MARG: RACK NO — store-specific
model ProductRackLocation {
  id             String       @id @default(cuid())
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  rackNo  String?
  shelfNo String?
  binNo   String?
  zone    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeProductId])
}

// =====================================================
// INVENTORY LEDGER — IMMUTABLE MOVEMENTS
// =====================================================

enum MovementType {
  OPENING_STOCK
  PURCHASE_RECEIPT
  PURCHASE_RETURN
  SALE_DEDUCTION
  SALE_RETURN
  DAMAGE_WRITE_OFF
  EXPIRY_WRITE_OFF
  MANUAL_ADJUSTMENT
  STOCK_COUNT_CORRECTION
  STOCK_TRANSFER_IN
  STOCK_TRANSFER_OUT
  RESERVATION
  RESERVATION_RELEASE
  // Legacy compatibility
  STOCK_RECEIVED
  POS_SALE
  ONLINE_ORDER_RESERVED
  ONLINE_ORDER_PICKED
  ORDER_CANCELLED
  RETURN_ACCEPTED
  DAMAGED
  EXPIRED
  SALE
  DAMAGE
  STOCK_ADJUSTMENT
}

model Inventory {
  id             String       @id @default(cuid())
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id])
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  batchNo    String?
  mfgDate    DateTime?
  expiryDate DateTime?
  rackNo     String?

  quantityBase Decimal @default(0) @db.Decimal(12, 3)
  reservedQty  Decimal @default(0) @db.Decimal(12, 3)
  blockedQty   Decimal @default(0) @db.Decimal(12, 3)

  movements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, storeProductId, batchNo])
  @@index([storeId, storeProductId])
  @@index([expiryDate])
}

// Materialized stock balance for fast reads
model StockBalance {
  id             String       @id @default(cuid())
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id])
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  balance          Decimal  @default(0) @db.Decimal(12, 3)
  lastMovementId   String?
  lastCalculatedAt DateTime @default(now())

  @@unique([storeId, storeProductId])
}

model StockMovement {
  id             String       @id @default(cuid())
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id])
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])
  inventoryId    String?
  inventory      Inventory?   @relation(fields: [inventoryId], references: [id])
  type           MovementType

  quantityDelta Decimal  @default(0) @db.Decimal(12, 3)
  previousQty   Decimal? @db.Decimal(12, 3)
  newQty        Decimal? @db.Decimal(12, 3)

  inputQuantity    Decimal? @db.Decimal(12, 3)
  inputUnit        String?
  conversionToBase Decimal? @db.Decimal(12, 5)

  supplierId String?
  sourceType String?
  sourceId   String?
  note       String?
  reason     String?
  createdBy  String?
  staffId    String?
  staff      User?   @relation(fields: [staffId], references: [id])

  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([storeProductId, type])
  @@index([sourceId])
}

// Product version snapshots
model ProductVersion {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  versionNo    Int
  snapshot     Json
  changedBy    String?
  changeReason String?
  createdAt    DateTime @default(now())
}

// =====================================================
// SUPPLIER / PARTY LEDGER — ERP GRADE
// =====================================================

// Base accounting ledger (MARG: Ledger screen)
model PartyLedger {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  // MARG: Ledger Name
  name             String
  // MARG: CODE (legacy ERP code)
  legacyCode       String?
  // MARG: Station
  station          String?
  // MARG: Account Group (SUNDRY CREDITORS, SUNDRY DEBTORS, etc.)
  accountGroup     String?
  // MARG: Balancing Method (Bill by Bill, Running Balance)
  balancingMethod  String?
  // MARG: Ledger Type (REGISTERED, UNREGISTERED, COMPOSITION, CONSUMER)
  ledgerType       String?
  // MARG: Ledger Category
  category         String?
  // MARG: Ledger Date
  ledgerDate       DateTime?
  // MARG: Freeze Upto
  freezeUpto       DateTime?
  // MARG: Hide
  isHidden         Boolean   @default(false)
  // MARG: ERP to ERP
  erpToErpEnabled  Boolean   @default(false)
  // MARG: Color
  colorType        String?
  // MARG: Bill Import source identifier
  billImportSource String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  openingBalances LedgerOpeningBalance[]
  contacts        SupplierContact[]
  addresses       SupplierAddress[]
  taxProfile      SupplierTaxProfile?
  paymentPolicy   SupplierPaymentPolicy?
  documents       SupplierDocument[]
  supplierProfile SupplierProfile?
  auditLogs       SupplierAuditLog[]

  @@unique([storeId, name])
  @@index([storeId])
}

// MARG: Opening Balance, Cr/Dr
model LedgerOpeningBalance {
  id            String      @id @default(cuid())
  partyLedgerId String
  partyLedger   PartyLedger @relation(fields: [partyLedgerId], references: [id])

  financialYear String?
  // Decimal(14,2) for large opening balances
  amount        Decimal   @db.Decimal(14, 2)
  // MARG: Cr/Dr
  balanceType   String // CR or DR
  asOfDate      DateTime?
  createdBy     String?

  createdAt DateTime @default(now())

  @@index([partyLedgerId])
}

// Links PartyLedger to the legacy Supplier table
model SupplierProfile {
  id            String      @id @default(cuid())
  partyLedgerId String      @unique
  partyLedger   PartyLedger @relation(fields: [partyLedgerId], references: [id])
  supplierId    String?     @unique
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])

  createdAt DateTime @default(now())
