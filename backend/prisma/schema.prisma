  unitSnapshot         String?
  barcodeSnapshot      String?
  mrpSnapshot          Decimal? @db.Decimal(12, 2)
  priceAtOrderSnapshot Decimal  @db.Decimal(12, 2)
  discountSnapshot     Decimal? @db.Decimal(5, 2)
  taxableValueSnapshot Decimal? @db.Decimal(12, 2)
  cgstRateSnapshot     Decimal? @db.Decimal(5, 2)
  cgstAmountSnapshot   Decimal? @db.Decimal(12, 2)
  sgstRateSnapshot     Decimal? @db.Decimal(5, 2)
  sgstAmountSnapshot   Decimal? @db.Decimal(12, 2)
  igstRateSnapshot     Decimal? @db.Decimal(5, 2)
  igstAmountSnapshot   Decimal? @db.Decimal(12, 2)
  cessRateSnapshot     Decimal? @db.Decimal(5, 2)
  cessAmountSnapshot   Decimal? @db.Decimal(12, 2)
  totalLineAmount      Decimal? @db.Decimal(12, 2)
}

