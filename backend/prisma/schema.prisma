  BLUETOOTH_SCANNER
  USB_HID_SCANNER
  POS_TERMINAL
  WEB_SCANNER
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  DECOMMISSIONED
}

model ScannerDevice {
