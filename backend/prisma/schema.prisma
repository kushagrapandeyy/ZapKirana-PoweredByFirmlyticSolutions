enum PaymentProvider {
  RAZORPAY
  CASH
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentSource {
  POS_BILL
  ONLINE_ORDER
}

model Payment {
  id                String          @id @default(cuid())
  storeId           String
  store             Store           @relation(fields: [storeId], references: [id])
  source            PaymentSource
  billId            String?
  orderId           String?
  provider          PaymentProvider @default(RAZORPAY)
