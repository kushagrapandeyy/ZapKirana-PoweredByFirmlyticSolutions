generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  legalName String?
  gstin     String?
  pan       String?
  plan      String   @default("FREE")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  stores         Store[]
  userStoreRoles UserStoreRole[]
}

model UserStoreRole {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  storeId         String
  store           Store        @relation(fields: [storeId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  role            Role
  permissionsJson Json?
  status          String       @default("ACTIVE")

  @@unique([storeId, userId])
}

model User {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  email          String        @unique
  password       String?
  pin            String?
  name           String?
  phone          String?       @unique
  role           Role          @default(CUSTOMER)
  storeId        String?
  store          Store?        @relation(fields: [storeId], references: [id])
  avatarUrl      String?
  isVerified     Boolean       @default(false)
  pushToken      String? // Expo push notification token
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  storeRoles             UserStoreRole[]
  movements              StockMovement[]
  posBills               PosBill[]
  customerOrders         Order[]          @relation("CustomerOrders")
  staffOrders            Order[]          @relation("StaffOrders")
  sentMessages           OrderMessage[]   @relation("SentMessages")
  audits                 AuditLog[]       @relation("UserAudits")
  savedAddresses         SavedAddress[]
  subscriptions          Subscription[]
  otpCodes               OtpCode[]
  assignedDevices        ScannerDevice[]  @relation("AssignedDevices")
  scannerEvents          ScannerEvent[]   @relation("ScannedByUser")
  printJobs              PrintJob[]       @relation("PrintJobs")
  pendingProductsCreated PendingProduct[] @relation("CreatedPendingProducts")
  ScannerSession         ScannerSession[]
  carts                  Cart[]
}

enum Role {
  OWNER
  PARTNER
  MANAGER
  STAFF
  DELIVERY
  CUSTOMER
  SCANNER_STAFF
  POS_CASHIER
  ORG_ADMIN
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  phone     String?
  email     String?
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([email])
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  label     String // e.g. "Home", "Office"
  streetAddress String?
  landmark  String?
  city      String?
  state     String?
  pincode   String?
  address   String
  latitude  Float
  longitude Float
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Store {
  id                  String                    @id @default(uuid())
  organizationId      String?
  organization        Organization?             @relation(fields: [organizationId], references: [id])
  name                String
  location            String?
  latitude            Float?
  longitude           Float?
  operatingRadiusKm   Float                     @default(3.0)
  gstin               String?
  isActive            Boolean                   @default(true)
  imageUrl            String?
  operatingHours      String? // JSON: {"mon": {"open": "08:00", "close": "22:00"}, ...}
  rating              Float                     @default(4.5)
  description         String?
  users               User[]
  userRoles           UserStoreRole[]
  products            Product[]
  inventory           Inventory[]
  movements           StockMovement[]
  posBills            PosBill[]
  orders              Order[]
  supplierConnections StoreSupplierConnection[]
  subscriptions       Subscription[]
  scannerDevices      ScannerDevice[]
  scannerEvents       ScannerEvent[]
  payments            Payment[]
  barcodeRegistry     BarcodeRegistry[]
  printJobs           PrintJob[]
  pendingProducts     PendingProduct[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  // Onboarding & Payment Details
  bankAccountNumber String?
  bankRoutingNumber String?
  taxId             String?

  purchaseOrders PurchaseOrder[]
  ScannerSession ScannerSession[]
  carts          Cart[]
}

// -----------------------------------------------------
// GST Classification System
// -----------------------------------------------------

enum GSTClass {
  EXEMPT // 0% - Essential items: milk, fresh vegetables, fruits, eggs
  GST_5 // 5% - Packaged food, edible oil, sugar, spices, tea, coffee
  GST_12 // 12% - Processed food, butter, cheese, ghee, fruit juices, namkeen
  GST_18 // 18% - Biscuits, pasta, cornflakes, soups, ice cream, sauces
  GST_28 // 28% - Aerated beverages, chewing gum, pan masala
}

model Product {
  id                 String              @id @default(uuid())
  storeId            String
  store              Store               @relation(fields: [storeId], references: [id])
  barcode            String?
  internalSku        String              @unique
  name               String
  description        String?
  category           String?
  mrp                Float
  sellingPrice       Float
  purchaseCost       Float?
  gstRate            Float               @default(0)
  gstClass           GSTClass            @default(EXEMPT)
  subscriptionDiscount Float             @default(0)
  imageUrl           String?
  isActive           Boolean             @default(true)
  inventory          Inventory[]
  movements          StockMovement[]
  posBillItems       PosBillItem[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  supplierProducts   SupplierProduct[]
  barcodeRegistry    BarcodeRegistry[]
  cartItems          CartItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([storeId])
  @@index([category])
  @@index([barcode]) // barcode lookup — HID scanner + platform search
  @@index([storeId, isActive]) // product catalog queries
  @@index([storeId, category]) // category browsing + analytics
}

model Inventory {
  id                String          @id @default(uuid())
  storeId           String
  store             Store           @relation(fields: [storeId], references: [id])
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  batchNo           String?
  expiryDate        DateTime?
  onHandQty         Int             @default(0)
  reservedQty       Int             @default(0)
  blockedQty        Int             @default(0)
  lowStockThreshold Int             @default(10)
  movements         StockMovement[]

  // Available Qty = onHandQty - reservedQty - blockedQty

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, productId, batchNo])
  @@index([storeId, productId]) // available stock lookups
  @@index([onHandQty]) // low stock alerts
  @@index([expiryDate]) // expiry queries
}

model StockMovement {
  id             String       @id @default(uuid())
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id])
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  inventoryId    String
  inventory      Inventory    @relation(fields: [inventoryId], references: [id])
  type           MovementType
  quantityChange Int
  sourceType     String? // e.g., "ONLINE_ORDER", "POS_SALE", "SUPPLIER_DELIVERY"
  sourceId       String?
  reason         String?
  staffId        String?
  staff          User?        @relation(fields: [staffId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([storeId, createdAt]) // analytics time-series queries
  @@index([productId, type]) // per-product movement history
  @@index([sourceId]) // trace by order/bill ID
}

enum MovementType {
  STOCK_RECEIVED
  POS_SALE
  ONLINE_ORDER_RESERVED
  ONLINE_ORDER_PICKED
  ORDER_CANCELLED
  RETURN_ACCEPTED
  DAMAGED
  EXPIRED
  MANUAL_ADJUSTMENT
  STOCK_COUNT_CORRECTION
}

enum BillStatus {
  DRAFT
  PAYMENT_PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

model PosBill {
  id        String     @id @default(uuid())
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  staffId   String?
  staff     User?      @relation(fields: [staffId], references: [id])
  status    BillStatus @default(DRAFT)
  subtotal  Float      @default(0)
  gst       Float      @default(0)
  total     Float      @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items    PosBillItem[]
  payments PosPayment[]

  @@index([storeId, status]) // POS revenue queries
  @@index([storeId, createdAt]) // daily/hourly heatmap analytics
}

model PosBillItem {
  id          String   @id @default(uuid())
  billId      String
  bill        PosBill  @relation(fields: [billId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  priceAtSale Float
  gstAtSale   Float    @default(0)
  createdAt   DateTime @default(now())
}

model PosPayment {
  id          String        @id @default(uuid())
  billId      String
  bill        PosBill       @relation(fields: [billId], references: [id])
  amount      Float
  method      PaymentMethod
  referenceId String?
  createdAt   DateTime      @default(now())
}

// -----------------------------------------------------
// Consumer Orders & Delivery
// -----------------------------------------------------

enum OrderStatus {
  PAYMENT_PENDING
  PAID
  PICKING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id                   String      @id @default(uuid())
  storeId              String
  store                Store       @relation(fields: [storeId], references: [id])
  customerId           String
  customer             User        @relation("CustomerOrders", fields: [customerId], references: [id])
  staffId              String? // Picker
  staff                User?       @relation("StaffOrders", fields: [staffId], references: [id])
  status               OrderStatus @default(PAYMENT_PENDING)
  totalAmount          Float       @default(0)
  deliveryFee          Float       @default(0)
  gstAmount            Float       @default(0)
  tipAmount            Float       @default(0)
  deliveryAddress      String?
  deliveryLat          Float?
  deliveryLng          Float?
  deliverySlot         String? // e.g., "10:00-11:00"
  deliveryInstructions String?
  requireOtp           Boolean     @default(false)
  otp                  String? // Generated OTP code
  subscriptionId       String? // If order was created from a subscription
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  items    OrderItem[]
  messages OrderMessage[]

  @@index([storeId, status]) // store order management
  @@index([customerId, createdAt]) // customer order history
  @@index([status, createdAt]) // platform-wide order monitoring
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  priceAtOrder Float
  gstAtOrder   Float    @default(0)
  gstClass     GSTClass @default(EXEMPT)
}

// -----------------------------------------------------
// Subscriptions (Recurring Orders)
// -----------------------------------------------------

enum SubscriptionFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id               String                @id @default(uuid())
  customerId       String
  customer         User                  @relation(fields: [customerId], references: [id])
  storeId          String
  store            Store                 @relation(fields: [storeId], references: [id])
  frequency        SubscriptionFrequency
  status           SubscriptionStatus    @default(ACTIVE)
  deliverySlot     String? // e.g., "07:00-08:00"
  nextDeliveryDate DateTime?
  customDays       Json?
  discountApplied  Float                 @default(0)
  items            SubscriptionItem[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([customerId])
  @@index([storeId])
}

model SubscriptionItem {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  productId      String
  productName    String // Denormalized for display
  quantity       Int
  createdAt      DateTime     @default(now())
}

// -----------------------------------------------------
// Supplier Network & Procurement
// -----------------------------------------------------

model Supplier {
  id           String   @id @default(uuid())
  name         String
  contactEmail String?
  contactPhone String?
  address      String?
  categories   String? // comma separated or JSON
  rating       Float    @default(5.0)
  description  String?
  logoUrl      String?
  paymentTerms String? // e.g., "Net 30", "COD"
  onTimeRate   Float    @default(100.0) // percentage
  fillRate     Float    @default(100.0) // percentage
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storeConnections StoreSupplierConnection[]
  purchaseOrders   PurchaseOrder[]
  supplierProducts SupplierProduct[]
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  REJECTED
}

model StoreSupplierConnection {
  id         String           @id @default(uuid())
  storeId    String
  store      Store            @relation(fields: [storeId], references: [id])
  supplierId String
  supplier   Supplier         @relation(fields: [supplierId], references: [id])
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([storeId, supplierId])
}

model OrderMessage {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  user       User?    @relation("UserAudits", fields: [userId], references: [id])
  details    String?
  createdAt  DateTime @default(now())
}

enum POStatus {
  CREATED
  SENT
  ACCEPTED
  PARTIALLY_ACCEPTED
  DELIVERED
  REJECTED
}

model PurchaseOrder {
  id                   String    @id @default(uuid())
  storeId              String
  store                Store     @relation(fields: [storeId], references: [id])
  supplierId           String
  supplier             Supplier  @relation(fields: [supplierId], references: [id])
  status               POStatus  @default(CREATED)
  expectedDeliveryDate DateTime?
  totalAmount          Float     @default(0)
  notes                String?
  shareToken           String?   @unique // For shareable link access
  shareTokenExpiresAt  DateTime? // Token expiry
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  items PurchaseOrderItem[]

  @@index([storeId, status]) // PO management dashboard
  @@index([supplierId, createdAt]) // supplier scorecard
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  poId             String
  po               PurchaseOrder @relation(fields: [poId], references: [id])
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  quantity         Int
  acceptedQuantity Int           @default(0)
  receivedQuantity Int           @default(0)
  purchasePrice    Float
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model SupplierProduct {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([supplierId, productId])
}

// -----------------------------------------------------
// GST Category Auto-Classification Rules
// -----------------------------------------------------

model GSTCategoryRule {
  id        String   @id @default(uuid())
  category  String   @unique // Product category name
  gstClass  GSTClass
  gstRate   Float // Numeric rate for calculation (0, 5, 12, 18, 28)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------
// Scanner Engine
// -----------------------------------------------------

enum DeviceType {
  ANDROID_PHONE
  BLUETOOTH_SCANNER
  USB_HID_SCANNER
  POS_TERMINAL
  WEB_SCANNER
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  DECOMMISSIONED
}

model ScannerDevice {
  id             String           @id @default(uuid())
  deviceCode     String           @unique
  storeId        String
  store          Store            @relation(fields: [storeId], references: [id])
  deviceName     String
  deviceType     DeviceType       @default(ANDROID_PHONE)
  assignedToId   String?
  assignedTo     User?            @relation("AssignedDevices", fields: [assignedToId], references: [id])
  lastSeenAt     DateTime?
  status         DeviceStatus     @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  events         ScannerEvent[]
  ScannerSession ScannerSession[]

  @@index([storeId, status])
}

enum ScannerWorkflow {
  GOODS_RECEIVING
  STOCK_AUDIT
  PRODUCT_INTAKE
  LOOSE_ITEM_PACKING
  ORDER_PICKING
  SHELF_REFILL
  DAMAGED_EXPIRED
  LABEL_REPRINT
  POS_BILLING
}

enum ScanResolutionStatus {
  FOUND
  UNKNOWN_BARCODE
  INTERNAL_BARCODE
  OPERATIONAL_BARCODE
  ERROR
}

model ScannerEvent {
  id               String               @id @default(uuid())
  storeId          String
  store            Store                @relation(fields: [storeId], references: [id])
  deviceId         String?
  device           ScannerDevice?       @relation(fields: [deviceId], references: [id])
  scannedById      String?
  scannedBy        User?                @relation("ScannedByUser", fields: [scannedById], references: [id])
  workflow         ScannerWorkflow
  rawValue         String
  symbology        String?
  parsedJson       Json?
  resolutionStatus ScanResolutionStatus @default(FOUND)
  idempotencyKey   String               @unique
  quantity         Int?
  metadata         Json?
  createdAt        DateTime             @default(now())

  @@index([storeId, workflow, createdAt])
  @@index([storeId, createdAt])
}

model ScannerSession {
  id              String        @id @default(uuid())
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id])
  deviceId        String
  device          ScannerDevice @relation(fields: [deviceId], references: [id])
  staffId         String
  staff           User          @relation(fields: [staffId], references: [id])
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  durationSeconds Int?

  @@index([storeId, startedAt])
  @@index([staffId])
}

// -----------------------------------------------------
// Razorpay Payments
// -----------------------------------------------------

enum PaymentProvider {
  RAZORPAY
  CASH
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentSource {
  POS_BILL
  ONLINE_ORDER
}

model Payment {
  id                String          @id @default(uuid())
  storeId           String
  store             Store           @relation(fields: [storeId], references: [id])
  source            PaymentSource
  billId            String? // PosBill reference (for POS payments)
  orderId           String? // Order reference (for online orders)
  provider          PaymentProvider @default(RAZORPAY)
  providerOrderId   String? // razorpay_order_id
  providerPaymentId String? // razorpay_payment_id
  providerQrId      String? // razorpay_qr_id
  amount            Float
  currency          String          @default("INR")
  method            String? // upi, card, netbanking, etc.
  status            PaymentStatus   @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  events            PaymentEvent[]

  @@index([storeId, status, createdAt])
  @@index([billId])
  @@index([orderId])
  @@index([providerOrderId])
}

model PaymentEvent {
  id             String    @id @default(uuid())
  paymentId      String
  payment        Payment   @relation(fields: [paymentId], references: [id])
  provider       String
  eventType      String
  payloadJson    Json
  signatureValid Boolean   @default(false)
  processedAt    DateTime?
  receivedAt     DateTime  @default(now())

  @@index([paymentId])
}

// -----------------------------------------------------
// Barcode Registry & Label Service
// -----------------------------------------------------

enum BarcodeScope {
  GS1_EXTERNAL_PRODUCT // EAN-13 / GTIN — manufacturer barcode
  INTERNAL_FIXED_PACK // e.g. BK01DALT1000 — internal fixed-weight
  INTERNAL_VARIABLE_WEIGHT // e.g. 29PPPPPWWWWWC — internal weighed item
  INTERNAL_OPERATIONAL // PO barcode, BIN barcode, Order QR
  UNKNOWN
}

model BarcodeRegistry {
  id           String       @id @default(uuid())
  storeId      String?
  store        Store?       @relation(fields: [storeId], references: [id])
  productId    String?
  product      Product?     @relation(fields: [productId], references: [id])
  barcodeValue String
  symbology    String       @default("EAN_13")
  barcodeScope BarcodeScope @default(GS1_EXTERNAL_PRODUCT)
  isInternal   Boolean      @default(false)
  isPrimary    Boolean      @default(true)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  @@unique([barcodeValue, storeId])
  @@index([barcodeValue])
  @@index([storeId, barcodeScope])
}

enum PrintJobStatus {
  PENDING
  READY
  PRINTED
  FAILED
}

model PrintJob {
  id            String         @id @default(uuid())
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id])
  requestedById String?
  requestedBy   User?          @relation("PrintJobs", fields: [requestedById], references: [id])
  templateType  String // LOOSE_ITEM_LABEL, SHELF_TAG, PO_LABEL, etc.
  labelDataJson Json // items + metadata for label rendering
  status        PrintJobStatus @default(PENDING)
  r2PdfPath     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([storeId, status])
}

// -----------------------------------------------------
// Pending Product Intake (Unknown barcode → approval flow)
// -----------------------------------------------------

enum PendingProductStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model PendingProduct {
  id                String               @id @default(uuid())
  storeId           String
  store             Store                @relation(fields: [storeId], references: [id])
  barcode           String?
  suggestedName     String?
  suggestedBrand    String?
  suggestedCategory String?
  mrp               Float?
  sellingPrice      Float?
  purchasePrice     Float?
  gstRate           Float                @default(0)
  imageUrl          String?
  status            PendingProductStatus @default(PENDING_REVIEW)
  createdById       String?
  createdBy         User?                @relation("CreatedPendingProducts", fields: [createdById], references: [id])
  approvedProductId String? // populated after approval
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([storeId, status])
}

// -----------------------------------------------------
// Consumer Carts
// -----------------------------------------------------

model Cart {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, storeId])
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@unique([cartId, productId])
}
