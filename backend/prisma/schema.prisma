// MARG: Contact Person, Designation, Mobile, Phone, Email, Website, Mail To
model SupplierContact {
  id            String      @id @default(cuid())
  partyLedgerId String
  partyLedger   PartyLedger @relation(fields: [partyLedgerId], references: [id])

  name           String?
  designation    String?
  mobile         String?
  officePhone    String?
  residencePhone String?
  fax            String?
  email          String?
  website        String?
  // MARG: Mail To
  mailToName     String?
  isPrimary      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partyLedgerId])
}

// MARG: Address, Pin Code, State, Country, Station
model SupplierAddress {
  id            String      @id @default(cuid())
  partyLedgerId String
  partyLedger   PartyLedger @relation(fields: [partyLedgerId], references: [id])

  addressType  String? // BILLING, SHIPPING, REGISTERED
  addressLine1 String?
  addressLine2 String?
  city         String?
  station      String?
  district     String?
  stateCode    String?
  stateName    String?
  pinCode      String?
  country      String? @default("INDIA")

  isDefaultBilling  Boolean @default(false)
  isDefaultShipping Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partyLedgerId])
}

// MARG: GSTIN, PAN, TIN, VAT, Food Licence, GSTN Verification
model SupplierTaxProfile {
  id            String      @id @default(cuid())
  partyLedgerId String      @unique
  partyLedger   PartyLedger @relation(fields: [partyLedgerId], references: [id])

  // MARG: GST Heading (Local/Central/Both)
  gstHeading              String?
  // MARG: GSTIN (15-char string)
  gstin                   String?
  // MARG: Ledger Type maps here too
  gstRegistrationType     String? // REGISTERED, UNREGISTERED, COMPOSITION, CONSUMER
  // MARG: I.T. PAN No.
  pan                     String?
  // MARG: TIN No.
  tinNumber               String?
  // MARG: VAT Heading
  vatNumber               String?
  // MARG: S.T. Heading
  serviceTaxNumber        String?
  // MARG: Food Heading / Food Licence No.
  foodLicenseNumber       String?
  // MARG: Extra Heading
  extraRegistrationNumber String?
  // MARG: Reg. No.
  registrationNumber      String?

  stateCode String?
  stateName String?
  country   String?

  // GSTN verification — stored separately from user-entered data
  gstnVerified     Boolean   @default(false)
  gstnVerifiedAt   DateTime?
  gstnLegalName    String?
  gstnTradeName    String?
  gstnStatus       String? // ACTIVE, CANCELLED, SUSPENDED
  gstnTaxpayerType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gstin])
  @@index([pan])
}

// MARG: Hold Payment, Hold Payment %, Credit Terms
model SupplierPaymentPolicy {
  id            String      @id @default(cuid())
  partyLedgerId String      @unique
  partyLedger   PartyLedger @relation(fields: [partyLedgerId], references: [id])

  // MARG: Hold Payment
  holdPayment        Boolean  @default(false)
  holdPaymentReason  String?
  // MARG: Hold Payment %
  holdPaymentPercent Decimal? @db.Decimal(5, 2)

  creditLimit        Decimal? @db.Decimal(14, 2)
  creditDays         Int?
  paymentTerms       String?
  defaultPaymentMode String?

  // MARG: if GSTR1 not uploaded, hold payment
  gstr1ComplianceRequired Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// MARG: Attach Documents
